# -----------------------------------------------------------------------
# JDoodle Compiler API credentials
# -----------------------------------------------------------------------
# 1. Sign up (free) at https://www.jdoodle.com/compiler-api
# 2. Copy your Client ID and Client Secret from the dashboard
# 3. Copy this file to .env.local and paste the values below
# 4. Restart the dev server (npm run dev) so vite reloads the env vars
#
# IMPORTANT: These are NOT prefixed with VITE_ on purpose.
# The Vite proxy reads them server-side and injects them into outbound
# requests to JDoodle. They never end up in the browser bundle, so they
# are safe.
# -----------------------------------------------------------------------

JDOODLE_CLIENT_ID=
JDOODLE_CLIENT_SECRET=
