# -----------------------------------------------------------------------
# JDoodle Compiler API credentials
# -----------------------------------------------------------------------
# 1. Sign up (free) at https://www.jdoodle.com/compiler-api
# 2. Copy your Client ID and Client Secret from the dashboard
# 3. Copy this file:
#      - to .env.local  for `npm run dev`
#      - to .env        for `docker compose up`
# 4. Paste the values below
#
# These are server-side env vars (no VITE_ prefix). They are read by
# either the Vite dev proxy or the production Express server, and are
# never bundled into the browser-side JavaScript.
# -----------------------------------------------------------------------

JDOODLE_CLIENT_ID=
JDOODLE_CLIENT_SECRET=
